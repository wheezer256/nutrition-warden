# NutritionWarden — required environment variables
# Copy to .env.local (gitignored) for local overrides, or set via openclaw.json skill env.

# ── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DB_CONN_STR=postgresql://user:password@host:5432/nutrition_warden

# Home Assistant base URL and long-lived access token
HA_URL=http://192.168.1.x:8123
HA_TOKEN=your_ha_token_here

# Google Calendar ID to create meal events in
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# Google account email used by the gog CLI
GOG_ACCOUNT=you@gmail.com

# LLM API endpoint (OpenAI-compatible, e.g. local llama.cpp or Groq)
LLM_API_URL=http://localhost:8080/v1/chat/completions

# ── Optional ─────────────────────────────────────────────────────────────────

# Override the model name (auto-detected from LLM_API_URL domain if not set)
# LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Groq API key — required only if LLM_API_URL points to api.groq.com,
# or for TikTok video transcription via Groq Whisper
# GROQ_API_KEY=gsk_...

# Google Keep sync — both required if using Keep shopping lists
# GKEEP_PY=/path/to/python3
# GKEEP_SCRIPT=/path/to/gkeep_sync.py

# Override gog binary location (default: resolved via PATH)
# GOG_BIN=/usr/local/bin/gog

# Override openclaw invocation (default: 'openclaw' from PATH)
# OPENCLAW_NODE=/path/to/node
# OPENCLAW_JS=/path/to/openclaw.js

# Override skill directory (used by briefing_cron.sh; default: ~/.openclaw/skills/nutrition-warden)
# SKILL_DIR=/home/you/.openclaw/skills/nutrition-warden

# Briefing recipients — space-separated E.164 numbers, required by briefing_cron.sh
# BRIEFING_RECIPIENTS="+12345000001 +12345000002"
